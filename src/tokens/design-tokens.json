{
  "$schema": "https://www.designtokens.org/TR/drafts/format/",
  "meta": {
    "name": "wpvite-design-system",
    "version": "1.0.0",
    "principles": [
      "semantic-naming",
      "single-source-of-truth",
      "llm-friendly-structure"
    ]
  },
  "color": {
    "primary": { "$type": "color", "$value": "oklch(0.56 0.21 262)" },
    "primaryHover": { "$type": "color", "$value": "oklch(0.49 0.21 262)" },
    "secondary": { "$type": "color", "$value": "oklch(0.64 0.14 195)" },
    "secondaryHover": { "$type": "color", "$value": "oklch(0.57 0.14 195)" },
    "tertiary": { "$type": "color", "$value": "oklch(0.74 0.15 88)" },
    "tertiaryHover": { "$type": "color", "$value": "oklch(0.67 0.15 88)" },
    "success": { "$type": "color", "$value": "oklch(0.66 0.17 152)" },
    "successHover": { "$type": "color", "$value": "oklch(0.59 0.17 152)" },
    "warning": { "$type": "color", "$value": "oklch(0.79 0.16 84)" },
    "warningHover": { "$type": "color", "$value": "oklch(0.72 0.16 84)" },
    "danger": { "$type": "color", "$value": "oklch(0.63 0.22 25)" },
    "dangerHover": { "$type": "color", "$value": "oklch(0.56 0.22 25)" },
    "info": { "$type": "color", "$value": "oklch(0.66 0.15 242)" },
    "background": { "$type": "color", "$value": "oklch(0.98 0.004 258)" },
    "surface": { "$type": "color", "$value": "oklch(1 0 0)" },
    "surfaceMuted": { "$type": "color", "$value": "oklch(0.95 0.01 258)" },
    "foreground": { "$type": "color", "$value": "oklch(0.23 0.02 258)" },
    "muted": { "$type": "color", "$value": "oklch(0.48 0.025 258)" },
    "border": { "$type": "color", "$value": "oklch(0.88 0.01 258)" },
    "onPrimary": { "$type": "color", "$value": "oklch(0.99 0.004 258)" },
    "onSecondary": { "$type": "color", "$value": "oklch(0.99 0.004 258)" },
    "onTertiary": { "$type": "color", "$value": "oklch(0.22 0.02 88)" },
    "onSuccess": { "$type": "color", "$value": "oklch(0.99 0.004 258)" },
    "onWarning": { "$type": "color", "$value": "oklch(0.22 0.02 88)" },
    "onDanger": { "$type": "color", "$value": "oklch(0.99 0.004 258)" }
  },
  "radius": {
    "buttonSm": { "$type": "dimension", "$value": "0.5rem" },
    "buttonMd": { "$type": "dimension", "$value": "0.75rem" },
    "buttonLg": { "$type": "dimension", "$value": "1rem" },
    "card": { "$type": "dimension", "$value": "1rem" },
    "pill": { "$type": "dimension", "$value": "9999px" }
  },
  "typography": {
    "fontFamily": {
      "display": {
        "$type": "fontFamily",
        "$value": ["Fraunces", "Iowan Old Style", "Palatino Linotype", "serif"]
      },
      "sans": {
        "$type": "fontFamily",
        "$value": ["Manrope", "Avenir Next", "Segoe UI", "sans-serif"]
      }
    },
    "lineHeight": {
      "tight": { "$type": "number", "$value": 1.1 },
      "snug": { "$type": "number", "$value": 1.25 },
      "normal": { "$type": "number", "$value": 1.55 }
    },
    "fontSize": {
      "step-2": { "$type": "dimension", "$value": "clamp(0.69rem, 0.67rem + 0.12vw, 0.76rem)" },
      "step-1": { "$type": "dimension", "$value": "clamp(0.83rem, 0.79rem + 0.2vw, 0.95rem)" },
      "step0": { "$type": "dimension", "$value": "clamp(1rem, 0.94rem + 0.29vw, 1.18rem)" },
      "step1": { "$type": "dimension", "$value": "clamp(1.2rem, 1.11rem + 0.45vw, 1.48rem)" },
      "step2": { "$type": "dimension", "$value": "clamp(1.44rem, 1.3rem + 0.7vw, 1.88rem)" },
      "step3": { "$type": "dimension", "$value": "clamp(1.73rem, 1.5rem + 1.12vw, 2.42rem)" },
      "step4": { "$type": "dimension", "$value": "clamp(2.07rem, 1.73rem + 1.71vw, 3.14rem)" },
      "step5": { "$type": "dimension", "$value": "clamp(2.49rem, 1.98rem + 2.55vw, 4.08rem)" }
    },
    "roles": {
      "body": { "$type": "dimension", "$value": "{typography.fontSize.step0}" },
      "h1": { "$type": "dimension", "$value": "{typography.fontSize.step5}" },
      "h2": { "$type": "dimension", "$value": "{typography.fontSize.step4}" },
      "h3": { "$type": "dimension", "$value": "{typography.fontSize.step3}" },
      "h4": { "$type": "dimension", "$value": "{typography.fontSize.step2}" },
      "h5": { "$type": "dimension", "$value": "{typography.fontSize.step1}" },
      "h6": { "$type": "dimension", "$value": "{typography.fontSize.step0}" }
    }
  }
}
